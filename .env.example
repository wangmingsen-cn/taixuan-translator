# ============================================================
# 太玄智译 - 环境变量配置文件
# 复制此文件为 .env 并填写实际值
# ============================================================

# ─── 应用基础 ────────────────────────────────────────────────
TAIXUAN_DEBUG=false
TAIXUAN_LOG_LEVEL=INFO
TAIXUAN_DEFAULT_ENGINE=deepseek
TAIXUAN_TARGET_LANGUAGE=zh-Hans
TAIXUAN_ENABLE_CACHE=true
TAIXUAN_CACHE_TTL_DAYS=30
TAIXUAN_BATCH_SIZE=10
TAIXUAN_MAX_CONCURRENT=3

# ─── DeepSeek（默认引擎）────────────────────────────────────
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=4096
DEEPSEEK_TEMPERATURE=0.3
DEEPSEEK_TIMEOUT=60
DEEPSEEK_MAX_RETRIES=3

# ─── OpenAI ──────────────────────────────────────────────────
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.3
OPENAI_TIMEOUT=60
OPENAI_MAX_RETRIES=3

# ─── 通义千问 (Qwen) ─────────────────────────────────────────
# 获取地址: https://dashscope.aliyun.com/
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-max
QWEN_MAX_TOKENS=4096
QWEN_TEMPERATURE=0.3
QWEN_TIMEOUT=60

# ─── Claude (Anthropic) ──────────────────────────────────────
# 获取地址: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-3-5-haiku-20241022
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.3
CLAUDE_TIMEOUT=60

# ─── Google Gemini ───────────────────────────────────────────
# 获取地址: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_TOKENS=4096
GEMINI_TEMPERATURE=0.3
GEMINI_TIMEOUT=60

# ─── MiniMax ─────────────────────────────────────────────────
# 获取地址: https://platform.minimaxi.com/
MINIMAX_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
MINIMAX_MODEL=MiniMax-Text-01
MINIMAX_MAX_TOKENS=4096
MINIMAX_TEMPERATURE=0.3
MINIMAX_TIMEOUT=60

# ─── Grok (xAI) ──────────────────────────────────────────────
# 获取地址: https://console.x.ai/
GROK_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-3-mini
GROK_MAX_TOKENS=4096
GROK_TEMPERATURE=0.3
GROK_TIMEOUT=60

# ─── DeepL ───────────────────────────────────────────────────
# 获取地址: https://www.deepl.com/pro-api
DEEPL_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:fx
# 免费版: https://api-free.deepl.com/v2
# 付费版: https://api.deepl.com/v2
DEEPL_API_URL=https://api-free.deepl.com/v2

# ─── Ollama（本地模型，无需 API Key）────────────────────────
# 启动命令: ollama serve
# 拉取模型: ollama pull qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120
OLLAMA_CONTEXT_WINDOW=8192

# ─── 自定义引擎（出版集团自建模型）─────────────────────────
# 任意 OpenAI 兼容接口均可接入
CUSTOM_API_KEY=your-key-or-leave-empty
CUSTOM_BASE_URL=https://your-api.example.com/v1
CUSTOM_MODEL=your-model-name
CUSTOM_MAX_TOKENS=4096
CUSTOM_TEMPERATURE=0.3
CUSTOM_TIMEOUT=60

# ─── PDF解析配置 ─────────────────────────────────────────────
PDF_DPI=150
PDF_FORMULA_CONFIDENCE=0.7
PDF_ENABLE_OCR=true
PDF_OCR_LANG=en,ch

# ─── Word生成配置（GB/T 7713.1-2006）────────────────────────
DOCX_FONT_NAME_CN=宋体
DOCX_FONT_NAME_EN=Times New Roman
DOCX_FONT_SIZE_BODY=10.5
DOCX_LINE_SPACING=1.5
DOCX_PAGE_MARGIN_TOP=2.54
DOCX_PAGE_MARGIN_BOTTOM=2.54
DOCX_PAGE_MARGIN_LEFT=3.17
DOCX_PAGE_MARGIN_RIGHT=3.17
